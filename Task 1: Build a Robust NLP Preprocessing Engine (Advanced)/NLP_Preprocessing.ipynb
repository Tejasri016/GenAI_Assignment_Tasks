   "source": [
    "# Task-2 Advanced Preprocessing Function\n",
    "import re\n",
    "\n",
    "def preprocess_text(text):\n",
    "    if not isinstance(text, str) or text.strip() == \"\":\n",
    "        return [], \"\"\n",
    "\n",
    "    # Lowercase\n",
    "    text = text.lower()\n",
    "\n",
    "    # Remove URLs\n",
    "    text = re.sub(r\"http\\S+|www\\S+\", \"\", text)\n",
    "\n",
    "    # Remove emails\n",
    "    text = re.sub(r\"\\S+@\\S+\", \"\", text)\n",
    "\n",
    "    # Remove numbers\n",
    "    text = re.sub(r\"\\d+\", \"\", text)\n",
    "\n",
    "    # Remove emojis & special chars (keep words)\n",
    "    text = re.sub(r\"[^\\w\\s]\", \"\", text)\n",
    "\n",
    "    # Handle repeated characters (soooo → soo)\n",
    "    text = re.sub(r'(.)\\1{2,}', r'\\1', text)\n",
    "\n",
    "    # Remove extra spaces\n",
    "    text = re.sub(r'\\s+', \" \", text).strip()\n",
    "\n",
    "    # Tokenization\n",
    "    tokens = text.split()\n",
    "\n",
    "    # Remove short words (except meaningful ones)\n",
    "    filtered_tokens = []\n",
    "    for word in tokens:\n",
    "        if len(word) > 2 or word in [\"no\", \"not\"]:\n",
    "            filtered_tokens.append(word)\n",
    "\n",
    "    clean_sentence = \" \".join(filtered_tokens)\n",
    "\n",
    "    return filtered_tokens, clean_sentence"
   ]
  },
