   "source": [
    "def full_pipeline(text_list):\n",
    "    all_tokens = []\n",
    "    clean_sentences = []\n",
    "\n",
    "    for text in text_list:\n",
    "        tokens, clean_sentence = preprocess_text(text)\n",
    "        all_tokens.extend(tokens)\n",
    "        clean_sentences.append(clean_sentence)\n",
    "\n",
    "    return {\n",
    "        \"tokens\": all_tokens,\n",
    "        \"clean_sentences\": clean_sentences\n",
    "    }"
   ]
  },
